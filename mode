import torch
import torch.nn as nn
from layers.SelfAttention_Family import AttentionLayer, FullAttention
from layers.Transformer_EncDec import Encoder, EncoderLayer


class HeterogeneousInvertedEmbedding(nn.Module):

    def __init__(self, seq_len, d_model, n_vars, dropout=0.1):
        super().__init__()
        self.var_embeds = nn.ModuleList(
            [nn.Linear(seq_len, d_model) for _ in range(n_vars)]
        )
        self.dropout = nn.Dropout(dropout)

    def forward(self, x_enc):
        B, L, N = x_enc.shape
        tokens = [self.var_embeds[i](x_enc[:, :, i]) for i in range(N)]
        return self.dropout(torch.stack(tokens, dim=1))  # [B, N, d_model]

class SharedEmbeddingWithID(nn.Module):
    def __init__(self, seq_len, d_model, n_vars, dropout=0.1):
        super().__init__()

        # 输入时间序列 x 用这个线性层投影
        self.value_embed = nn.Linear(seq_len, d_model)

        # 变量编号 0~N-1 用这个 Embedding 查表
        self.channel_id_embed = nn.Embedding(n_vars, d_model)

        self.dropout = nn.Dropout(dropout)

    def forward(self, x_enc):
        # x_enc: [B, L, N]
        B, L, N = x_enc.shape

        x = x_enc.permute(0, 2, 1)  # [B, N, L]

        # 浮点输入给 Linear
        token_embed = self.value_embed(x)  # [B, N, d_model]

        # 整数编号给 Embedding
        channel_ids = torch.arange(
            N, device=x_enc.device, dtype=torch.long
        )

        id_embed = self.channel_id_embed(channel_ids).unsqueeze(0)
        # [1, N, d_model]

        return self.dropout(token_embed + id_embed)


class Model(nn.Module):

    def __init__(self, configs):
        super(Model, self).__init__()
        self.task_name = configs.task_name
        self.seq_len = configs.seq_len
        self.pred_len = configs.pred_len
        self.n_vars = getattr(configs, "enc_in", 6)

        self.output_attention = False
        #
        self.enc_embedding = HeterogeneousInvertedEmbedding(
            configs.seq_len, configs.d_model, self.n_vars, configs.dropout
        )
        # self.enc_embedding = SharedEmbeddingWithID(
        #     configs.seq_len, configs.d_model, self.n_vars, configs.dropout
        # )

        self.encoder = Encoder(
            [
                EncoderLayer(
                    AttentionLayer(
                        FullAttention(
                            False,
                            configs.factor,
                            attention_dropout=configs.dropout,
                            output_attention=True,
                        ),
                        configs.d_model,
                        configs.n_heads,
                    ),
                    configs.d_model,
                    configs.d_ff,
                    dropout=configs.dropout,
                    activation=configs.activation,
                )
                for l in range(configs.e_layers)
            ],
            norm_layer=torch.nn.LayerNorm(configs.d_model),
        )

        self.projection = nn.Sequential(
            nn.Linear(configs.d_model, configs.pred_len, bias=True), nn.ReLU()
        )

    def forecast(self, x_enc, x_mark_enc, x_dec, x_mark_dec):

        mins = x_enc.min(dim=1, keepdim=True)[0].detach()
        maxs = x_enc.max(dim=1, keepdim=True)[0].detach()

        alpha = 0.075

        upper_raw = (1.0 + alpha) * maxs

        upper_fallback = maxs + alpha * (maxs - mins).clamp_min(1e-5)

        upper = torch.where(
            upper_raw > mins,
            upper_raw,
            upper_fallback
        )

        ranges = upper - mins + 1e-5
        x_enc = (x_enc - mins) / ranges


        B, L, N = x_enc.shape


        enc_out = self.enc_embedding(x_enc)  # [B, N, d_model]


        enc_out, attn = self.encoder(enc_out, attn_mask=None)

        dec_out = self.projection(enc_out).permute(0, 2, 1)[
            :, :, :N
        ]  # [B, pred_len, N]

        dec_out = dec_out * ranges + mins
        return dec_out,attn

    def forward(self, x_enc, x_mark_enc, x_dec, x_mark_dec, mask=None):
        dec_out,attn = self.forecast(x_enc, x_mark_enc, x_dec, x_mark_dec)
        res=dec_out[:, -self.pred_len :, :]
        # return dec_out[:, -self.pred_len :, :]
        if self.output_attention:
            return res, attn
        else:
            return res
